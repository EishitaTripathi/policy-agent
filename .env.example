# Policy Agent — environment configuration
#
# Default: local Ollama with llama3.1:8b. Reviewers should:
#   brew install ollama
#   ollama serve &
#   ollama pull llama3.1:8b
#
# To swap to a hosted provider, change LLM_PROVIDER and the corresponding
# *_API_KEY. The codebase uses litellm so any OpenAI-compatible endpoint
# works without code changes.

# --- Reasoning agent (LLM #1) — Groq 70B by default ---
# Per the post-pilot finding: llama3.1:8b cannot reliably perform the
# conditional reasoning the agent needs (e.g. recognizing that "Blue =
# upstream-verified identity" satisfies a §13.5-style "verify identity
# through MFA OR OTHER SECURE MEANS" precondition). Pivoted both reasoner
# and judges to Groq 70B; free tier covers the eval suite.
#
# Local-only fallback (degraded mode): set LLM_MODEL=ollama_chat/llama3.1:8b
# and LLM_BASE_URL=http://localhost:11434 — multiple scenarios will fail
# in expected ways (documented in README failure-analysis).
#
# Format: <provider>/<model> as understood by litellm.
LLM_MODEL=groq/llama-3.3-70b-versatile

# Only used when LLM_MODEL points at Ollama:
LLM_BASE_URL=http://localhost:11434

# --- Judge models (LLM #2 / #3) — hosted 70B by default ---
# Per the design (D5/D13): citation verification and final consistency
# reviewer are routed to a 70B-class model because 8B-class judges are
# empirically unreliable on factual judgments (JudgeBench, Patronus Lynx).
JUDGE_MODEL=groq/llama-3.3-70b-versatile

# Required for hosted judge calls.
# GROQ_API_KEY=...

# Optional alternatives (uncomment to use)
# GEMINI_API_KEY=
# TOGETHER_API_KEY=

# --- Embeddings (local; no API key needed) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Reranker (local; downloaded on first use) ---
RERANKER_MODEL=BAAI/bge-reranker-base

# --- Prompt-injection classifier (D8) ---
PROMPT_GUARD_MODEL=meta-llama/Llama-Prompt-Guard-2-86M

# --- Retrieval ---
CHROMA_PATH=.chroma
CHROMA_COLLECTION=gaggia_policy
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5

# --- Tracing (Phoenix) ---
PHOENIX_ENABLED=true
PHOENIX_PORT=6006

# --- Eval ---
EVAL_REPORT_PATH=docs/eval-report.md
